*.iml
*.ipr
*.iws
.vscode/
.project
.classpath
.settings/
*.swp
*.swo
*~
.DS_Store
.factorypath

# ============================================================================
#  Logs
# ============================================================================
*.log
logs/
hs_err_pid*

# ============================================================================
#  OS
# ============================================================================
Thumbs.db

# ============================================================================
